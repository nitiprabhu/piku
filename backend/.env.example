# App
APP_ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string-here
FRONTEND_URL=http://localhost:3000

# Database (defaults work with docker-compose)
DATABASE_URL=postgresql+asyncpg://reelcraft:password@postgres:5432/reelcraft
SYNC_DATABASE_URL=postgresql://reelcraft:password@postgres:5432/reelcraft
REDIS_URL=redis://redis:6379/0

# AI APIs
OPENAI_API_KEY=sk-...
MUAPI_API_KEY=...

# Cloudflare R2 (leave blank to use local /static fallback in dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=reelcraft-media
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Social OAuth
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMS/OTP via Twilio (leave blank in dev — OTP returned in API response)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SENDER_NUMBER=+1xxxxxxxxxx
